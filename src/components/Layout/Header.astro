---
/**
 * Header/Navegación superior - Componente para página principal
 * Solo muestra logo y ThemeToggle (sin menú hamburguesa)
 */
import ThemeToggle from '../UI/ThemeToggle.astro';
---

<nav class="top-nav">
  <div class="nav-content">
    <a href="/" class="nav-brand">
      <span class="nav-logo">🎓</span>
      <span class="nav-name">Ediprofe</span>
    </a>
    <div class="nav-actions">
      <a href="/miembros/login" class="nav-member-link">Ingresar a miembros</a>
      <ThemeToggle />
    </div>
  </div>
</nav>

<style>
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.625rem 1.5rem;
    background: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nav-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: white;
  }

  .nav-brand:hover {
    text-decoration: none;
  }

  .nav-logo {
    font-size: 1.5rem;
  }

  .nav-name {
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-member-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.08);
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.16s ease, transform 0.16s ease;
  }

  .nav-member-link:hover {
    text-decoration: none;
    background: rgba(255, 255, 255, 0.14);
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .nav-member-link {
      display: none;
    }
  }
</style>
