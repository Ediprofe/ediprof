---
import PracticeLessonLayout from '../../../layouts/PracticeLessonLayout.astro';
---

<PracticeLessonLayout
  title="Asignación académica"
  description="Resuelve tu asignación con guardado de intento y seguimiento desde el backend académico."
  materia="quimica"
  badge="Asignación"
  icon="📝"
  breadcrumbItems={[
    { label: 'Inicio', href: '/', icon: '🏠' },
    { label: 'Miembros', href: '/miembros', icon: '👥' },
    { label: 'Asignaciones', href: '/miembros/asignaciones', icon: '📝' },
    { label: 'Abrir asignación' },
  ]}
  contentClass="saber-taller"
>
  <div class="practice-surface">
    <div class="members-actions">
      <a class="members-button secondary" href="/miembros/asignaciones">Volver a asignaciones</a>
    </div>
    <div id="practice-feedback"></div>
    <div id="practice-player">
      <div class="members-alert">Preparando la asignación...</div>
    </div>
  </div>
</PracticeLessonLayout>

<script>
  import {
    apiAnswerAssessmentAttempt,
    apiAssessmentAttempt,
    apiMe,
    apiMyAssignment,
    apiStartAssignmentAttempt,
    apiSubmitAssessmentAttempt,
    clearSession,
    getSessionToken,
    saveSession,
  } from '../../../scripts/members/client';
  import { mountPracticePlayer } from '../../../scripts/members/practicePlayer';

  const token = getSessionToken();
  if (!token) {
    window.location.href = '/miembros/login';
  }

  const feedback = document.getElementById('practice-feedback');
  const root = document.getElementById('practice-player');

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function renderNotice(message, type = 'warning', title = '') {
    const heading = title ? `<strong>${escapeHtml(title)}</strong><br />` : '';
    return `<div class="members-alert ${escapeHtml(type)}">${heading}${escapeHtml(message)}</div>`;
  }

  async function boot() {
    try {
      const params = new URLSearchParams(window.location.search);
      const assignmentId = (params.get('id') || '').trim();
      if (!assignmentId) {
        root.innerHTML = '<div class="members-alert error">No se encontró el identificador de la asignación.</div>';
        return;
      }

      const me = await apiMe();
      const user = me?.data?.user;
      if (!user) throw new Error('Sesión inválida.');
      saveSession(token, user);

      const response = await apiMyAssignment(assignmentId);
      const assignment = response?.data;
      if (!assignment) {
        root.innerHTML = '<div class="members-alert error">No fue posible cargar la asignación solicitada.</div>';
        return;
      }

      const latestAttemptId =
        typeof assignment?.latest_attempt?.id === 'string' && assignment.latest_attempt.id.trim() !== ''
          ? assignment.latest_attempt.id.trim()
          : null;
      const canStart = Boolean(assignment?.availability?.can_start);
      const notices = [];

      if (assignment?.feedback?.message) {
        notices.push(
          renderNotice(
            assignment.feedback.message,
            assignment?.feedback?.available ? 'ok' : 'warning',
            assignment?.feedback?.policy_label || 'Retroalimentación'
          )
        );
      }

      if (!canStart && !latestAttemptId) {
        const message =
          assignment?.availability?.message || 'Esta asignación no está disponible para iniciar nuevos intentos.';
        notices.push(renderNotice(message, 'warning', 'Disponibilidad'));
        feedback.innerHTML = notices.join('');
        root.innerHTML = '<div class="members-alert">No tienes un intento previo para revisar en este momento.</div>';
        return;
      }

      if (!canStart && latestAttemptId) {
        const message =
          assignment?.availability?.message || 'Esta asignación ya no admite nuevos intentos, pero puedes consultar tu resultado o retroalimentación.';
        notices.push(renderNotice(message, 'warning', 'Seguimiento del intento'));
      }

      feedback.innerHTML = notices.join('');

      const allowedModes = assignment.mode === 'study' ? ['study'] : ['exam'];
      const defaultMode = assignment.mode === 'study' ? 'study' : 'exam';
      const contentLabel =
        assignment.mode === 'evaluation'
          ? 'Evaluación asignada'
          : assignment.mode === 'study'
          ? 'Estudio guiado asignado'
          : 'Simulacro asignado';
      const examContentName = assignment.mode === 'evaluation' ? 'evaluación' : 'simulacro';

      mountPracticePlayer({
        root,
        feedback,
        contentId: assignment.id,
        contentType: 'assignment',
        contentLabel,
        backHref: '/miembros/asignaciones',
        allowedModes,
        defaultMode,
        examContentName,
        api: {
          getSessionToken,
          clearSession,
          saveSession,
          me: apiMe,
          startAttempt: (contentId, options = {}) =>
            canStart
              ? apiStartAssignmentAttempt(contentId, options)
              : apiAssessmentAttempt(latestAttemptId),
          getAttempt: apiAssessmentAttempt,
          answerAttempt: apiAnswerAssessmentAttempt,
          submitAttempt: apiSubmitAssessmentAttempt,
        },
      });
    } catch (error) {
      const message = error instanceof Error ? error.message : 'No fue posible abrir la asignación.';
      root.innerHTML = `<div class="members-alert error">${escapeHtml(message)}</div>`;
    }
  }

  boot();
</script>
