---
import MembersEditorialLayout from '../../../layouts/MembersEditorialLayout.astro';
---

<MembersEditorialLayout
  title="Evaluaciones"
  description="Aquí ves lo que tu docente te dejó asignado: iniciar, continuar, revisar resultados o abrir retroalimentación cuando ya esté disponible."
  badge="Evaluaciones"
  icon="📝"
  breadcrumbTrail={[{ label: 'Evaluaciones' }]}
  activeSection="evaluaciones"
>
  <div class="practice-surface members-editorial-stack">
    <section class="members-card">
      <div id="feedback"></div>
      
      <div id="summary" class="u-margin-bottom-large"></div>
      
      <div class="members-list-header">
        <div class="members-item-main">
          <h3 class="members-section-title">📋 Tus evaluaciones del docente</h3>
          <p class="members-subtitle">Si una ya fue entregada, desde aquí mismo vuelves a ver el resultado o la retroalimentación.</p>
        </div>
        <div class="members-actions">
          <a class="members-button secondary" href="/miembros">Volver al panel</a>
        </div>
      </div>
      <div id="assignments" class="members-list members-list--loose"></div>
    </section>
  </div>
</MembersEditorialLayout>

<script>
  import { apiMe, apiMyAssignments, clearSession, getSessionToken, saveSession } from '../../../scripts/members/client';

  const token = getSessionToken();
  if (!token) {
    window.location.href = '/miembros/login';
  }

  const feedback = document.getElementById('feedback');
  const summary = document.getElementById('summary');
  const assignmentsWrap = document.getElementById('assignments');
  const LAST_ASSIGNMENT_KEY = 'ediprofe_member_last_assignment';

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function modeLabel(mode) {
    if (mode === 'study') return 'Práctica guiada';
    if (mode === 'evaluation') return 'Evaluación';
    return 'Simulacro';
  }

  function availabilityLabel(availability) {
    const state = availability?.state || 'active';
    if (state === 'scheduled') return 'Programada';
    if (state === 'closed') return 'Cerrada';
    if (state === 'draft') return 'Borrador';
    return 'Disponible';
  }

  function availabilityClass(availability) {
    const state = availability?.state || 'active';
    if (state === 'scheduled') return 'pending';
    if (state === 'closed' || state === 'draft') return 'blocked';
    return 'approved';
  }

  function actionLabel(item) {
    const latest = item?.latest_attempt;
    if (latest?.status === 'in_progress') return 'Continuar';
    if (latest?.status === 'submitted' || latest?.status === 'graded' || latest?.status === 'released') {
      return latest?.can_review ? 'Revisar retroalimentación' : 'Ver resultado';
    }
    return item?.availability?.can_start ? 'Iniciar ahora' : 'Ver detalles';
  }

  function attemptStatusLabel(status) {
    if (status === 'in_progress') return 'En progreso';
    if (status === 'submitted') return 'Entregada';
    if (status === 'graded') return 'Calificada';
    if (status === 'released') return 'Retro liberada';
    return 'Sin intento';
  }

  function feedbackLabel(feedback) {
    return feedback?.state_label || feedback?.policy_label || 'Retroalimentación';
  }

  function feedbackClass(feedback) {
    const state = feedback?.state || '';
    if (state === 'available') return 'approved';
    return 'pending';
  }

  function buildLink(id) {
    return `/miembros/asignaciones/abrir?id=${encodeURIComponent(id)}`;
  }

  async function boot() {
    try {
      const me = await apiMe();
      const user = me?.data?.user;
      if (!user) throw new Error('Sesión inválida.');

      saveSession(token, user);

      if (user.member_status === 'blocked' && user.role !== 'admin') {
        feedback.innerHTML = `
          <div class="members-alert error">
            Acceso bloqueado. Contacta al administrador.
          </div>
        `;
        return;
      }

      const response = await apiMyAssignments();
      const items = Array.isArray(response?.data) ? response.data : [];

      if (items.length === 0) {
        assignmentsWrap.innerHTML =
          '<div class="members-alert">No tienes evaluaciones programadas.</div>';
        return;
      }

      const activeNow = items.filter((item) => item?.availability?.can_start);
      const reviewable = items.filter((item) => item?.latest_attempt?.can_review).length;
      const evaluations = items.filter((item) => item?.mode === 'evaluation').length;

      summary.innerHTML = `
        <div class="members-grid summary-stats">
          <article class="members-item stat-box">
            <p class="members-subtitle">Activas</p>
            <p class="stat-value" style="color: #27ae60;">${activeNow.length}</p>
          </article>
          <article class="members-item stat-box">
            <p class="members-subtitle">Registradas</p>
            <p class="stat-value">${items.length}</p>
          </article>
          <article class="members-item stat-box">
            <p class="members-subtitle">Modo evaluación</p>
            <p class="stat-value" style="color: var(--color-primary);">${evaluations}</p>
          </article>
          <article class="members-item stat-box">
            <p class="members-subtitle">Con Retro</p>
            <p class="stat-value" style="color: #f39c12;">${reviewable}</p>
          </article>
        </div>
      `;

      assignmentsWrap.innerHTML = items
        .map((item) => {
          const link = buildLink(item.id);
          const latest = item.latest_attempt;
          const status = availabilityClass(item.availability);
          const feedbackState = feedbackClass(item.feedback);
          const statusModifier = status === 'approved' ? 'approved' : status === 'pending' ? 'pending' : 'blocked';

          return `
            <article class="members-item members-item--${statusModifier}">
              <div class="u-flex-between">
                <div class="members-item-main">
                  <h4 class="u-margin-bottom-small" style="font-size: 1.25rem;">${escapeHtml(item.title)}</h4>
                  <p class="members-subtitle u-margin-bottom-medium" style="font-size: 1rem;">
                    🎯 ${escapeHtml(modeLabel(item.mode))} · 📄 ${Number(item?.stats?.effective_questions || 0)} preguntas
                  </p>
                  
                  <div class="u-flex-wrap u-flex-gap-small u-margin-bottom-medium">
                    <span class="members-pill ${status}">${escapeHtml(availabilityLabel(item.availability))}</span>
                    ${
                      item?.course?.name
                        ? `<span class="members-pill approved">🎓 ${escapeHtml(item.course.name)}</span>`
                        : ''
                    }
                    ${
                      item?.feedback
                        ? `<span class="members-pill ${feedbackState}">💬 ${escapeHtml(feedbackLabel(item.feedback))}</span>`
                        : ''
                    }
                  </div>
                  
                  ${
                    latest
                      ? `
                    <div class="members-card" style="padding: 0.75rem 1rem; margin: 0; background: color-mix(in oklab, var(--bg-secondary) 50%, var(--bg-primary)); border-radius: 12px; border: 1px dashed var(--border-color);">
                      <p style="margin: 0; font-size: 0.9rem; font-weight: 600;">
                        Último estado: <span class="members-pill pending" style="padding: 0.1rem 0.5rem; margin-left: 0.25rem;">${escapeHtml(attemptStatusLabel(latest.status || ''))}</span>
                        ${item?.attempts?.limit ? `<span style="margin-left: 1rem; color: var(--text-secondary); font-size: 0.85rem;">(Uso: ${Number(item?.attempts?.used || 0)}/${Number(item?.attempts?.limit || 0)})</span>` : ''}
                      </p>
                    </div>
                    `
                      : ''
                  }
                </div>
                
                <div class="members-actions" style="min-width: 150px; justify-content: flex-end;">
                  <a class="members-button ${status === 'approved' ? '' : 'secondary'}" href="${link}" data-link="${escapeHtml(link)}" data-title="${escapeHtml(item.title)}" style="width: 100%; padding: 0.8rem;">
                    ${escapeHtml(actionLabel(item))}
                  </a>
                </div>
              </div>
              
              ${
                item?.availability?.message || item?.feedback?.message
                  ? `<div class="members-info-bar">
                      ${item?.availability?.message ? `<p>ℹ️ ${escapeHtml(item.availability.message)}</p>` : ''}
                      ${item?.feedback?.message ? `<p>📝 ${escapeHtml(item.feedback.message)}</p>` : ''}
                    </div>`
                  : ''
              }
            </article>
          `;
        })
        .join('');

      assignmentsWrap.querySelectorAll('a[data-link]').forEach((anchor) => {
        anchor.addEventListener('click', () => {
          const link = anchor.getAttribute('data-link');
          const title = anchor.getAttribute('data-title');
          if (!link) return;
          window.localStorage.setItem(
            LAST_ASSIGNMENT_KEY,
            JSON.stringify({
              link,
              title: title || 'Evaluación',
              at: Date.now(),
              })
          );
        });
      });
    } catch (error) {
      clearSession();
      window.location.href = '/miembros/login';
    }
  }

  boot();
</script>
