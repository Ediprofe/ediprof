---
import { getCollection } from 'astro:content';
import MembersEditorialLayout from '../../../layouts/MembersEditorialLayout.astro';
import { getMateriaConfig, getMateriaName } from '../../../config/materias';
import { cleanSlug } from '../../../utils/navigation-generator.js';
import '../../../styles/layouts/practice-lesson.css';
import '../../../styles/saber/preguntas-icfes.css';

export async function getStaticPaths() {
  const simulacros = await getCollection('simulacros');
  const paths = new Map();

  for (const simulacro of simulacros) {
    const normalized = cleanSlug(simulacro.slug);
    const simulacroId = `content:simulacros:${normalized}`;
    const encoded = Buffer.from(simulacroId, 'utf8').toString('base64url');
    const [materiaSlug = 'quimica'] = normalized.split('/');
    const config = getMateriaConfig(materiaSlug);
    const title = simulacro.data.title || `Simulacro de ${getMateriaName(materiaSlug)}`;
    const description =
      simulacro.data.description || 'Elige entre modo simulacro y estudio guiado para practicar con retroalimentación.';

    paths.set(encoded, {
      params: { id: encoded },
      props: {
        simulacroId,
        title,
        description,
        materiaSlug,
        materiaIcon: config.icon,
      },
    });
  }

  return Array.from(paths.values());
}

const {
  simulacroId,
  title,
  description,
  materiaSlug = 'quimica',
  materiaIcon = '🧪',
} = Astro.props;
const materiaName = getMateriaName(materiaSlug);
---

<MembersEditorialLayout
  title={title}
  description={description}
  badge="Simulacros"
  icon={materiaIcon}
  breadcrumbTrail={[
    { label: 'Simulacros', href: '/miembros/simulacros', icon: '🚀' },
    { label: materiaName },
    { label: title },
  ]}
  contentClass="members-container--workshop saber-taller"
  showPageIntro={false}
  showBreadcrumb={false}
  activeSection="simulacros"
>
  <div class="practice-surface members-editorial-stack">
    <div class="members-actions">
      <a class="members-button secondary" href="/miembros/simulacros">Volver a simulacros</a>
      <button type="button" class="members-button warn" id="reset-progress-btn">Reiniciar progreso</button>
    </div>
    <div id="practice-feedback"></div>
    <div id="practice-player"></div>
  </div>
</MembersEditorialLayout>

<script define:vars={{ simulacroId }}>
  window.__EDIPROFE_PRACTICE_ID__ = simulacroId;
</script>

<script>
  import {
    apiAnswerAssessmentAttempt,
    apiAssessmentAttempt,
    apiMe,
    apiStartSimulacroAttempt,
    apiSubmitAssessmentAttempt,
    clearSession,
    getSessionToken,
    saveSession,
  } from '../../../scripts/members/client';
  import { mountPracticePlayer } from '../../../scripts/members/practicePlayer';

  mountPracticePlayer({
    root: document.getElementById('practice-player'),
    feedback: document.getElementById('practice-feedback'),
    resetButton: document.getElementById('reset-progress-btn'),
    contentId: window.__EDIPROFE_PRACTICE_ID__,
    contentType: 'simulacro',
    contentLabel: 'Simulacro interactivo',
    backHref: '/miembros/simulacros',
    allowedModes: ['exam', 'study'],
    defaultMode: 'exam',
    api: {
      getSessionToken,
      clearSession,
      saveSession,
      me: apiMe,
      startAttempt: apiStartSimulacroAttempt,
      getAttempt: apiAssessmentAttempt,
      answerAttempt: apiAnswerAssessmentAttempt,
      submitAttempt: apiSubmitAssessmentAttempt,
    },
  });
</script>
