---
import MembersEditorialLayout from '../../layouts/MembersEditorialLayout.astro';
---

<MembersEditorialLayout
  title="Redirigiendo al panel admin"
  description="Te llevamos al backoffice académico de Ediprofe en Laravel + Filament."
  badge="Administración"
  icon="🗂️"
  breadcrumbTrail={[{ label: 'Administración' }]}
  showSectionNav={false}
>
  <div class="practice-surface members-editorial-stack">
    <section class="members-card">
      <div id="handoff-status" class="members-alert">Validando tu sesión de administrador…</div>
    </section>
  </div>
</MembersEditorialLayout>

<script>
  import {
    apiAdminPanelHandoff,
    apiMe,
    getSessionToken,
    saveSession,
  } from '../../scripts/members/client';

  const token = getSessionToken();
  const status = document.getElementById('handoff-status');

  if (!token) {
    window.location.href = '/miembros/login';
  }

  async function boot() {
    try {
      const me = await apiMe();
      const user = me?.data?.user;

      if (!user) {
        throw new Error('No se pudo validar tu sesión.');
      }

      saveSession(token, user);

      if (user.role !== 'admin') {
        status.innerHTML = 'Tu cuenta no tiene permisos de administración.';
        status.classList.add('error');
        return;
      }

      status.textContent = 'Abriendo el panel administrativo…';

      const handoff = await apiAdminPanelHandoff('/admin');
      const url = handoff?.data?.url;

      if (!url) {
        throw new Error('No se pudo generar el acceso al panel.');
      }

      window.location.href = url;
    } catch (error) {
      status.textContent = error instanceof Error ? error.message : 'No se pudo abrir el panel administrativo.';
      status.classList.add('error');
    }
  }

  boot();
</script>
