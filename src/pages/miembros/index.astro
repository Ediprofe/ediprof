---
import MembersEditorialLayout from '../../layouts/MembersEditorialLayout.astro';
---

<MembersEditorialLayout
  title="Panel del estudiante"
  description="Aquí entras directo a tus evaluaciones del docente, tus talleres por tema y tus simulacros completos."
  badge="Miembros"
  icon="🧭"
  activeSection="panel"
>
  <div class="practice-surface members-editorial-stack">
    <section class="members-card profile-hero">
      <div id="profile"></div>
      <div id="feedback"></div>
    </section>

    <section class="members-card">
      <div class="members-list-header">
        <div class="members-item-main">
          <h3 class="members-section-title">🧭 ¿Qué quieres hacer hoy?</h3>
          <p class="members-subtitle">Escoge una ruta clara según lo que vas a resolver: docente, práctica o examen.</p>
        </div>
      </div>
      <div id="route-cards" class="members-quick-links"></div>
    </section>

    <div class="members-editorial-grid">
      <section class="members-card">
        <h3 class="members-section-title">📌 Evaluaciones del docente</h3>
        <div id="assignment-summary"></div>
      </section>

      <section class="members-card">
        <h3 class="members-section-title">🎓 Cursos activos</h3>
        <div id="courses-summary"></div>
      </section>
    </div>

    <section class="members-actions u-margin-top-medium" style="justify-content: center;">
      <a class="members-button secondary" href="/miembros/admin" id="admin-link" style="display:none;">⚙️ Administración</a>
      <button class="members-button warn" id="logout-btn" type="button">🚪 Cerrar sesión</button>
    </section>
  </div>
</MembersEditorialLayout>

<script>
  import {
    apiLogout,
    apiMe,
    apiMyAssignments,
    apiMyCourses,
    apiMyLibrary,
    clearSession,
    getSessionToken,
    saveSession,
  } from '../../scripts/members/client';

  const token = getSessionToken();
  if (!token) {
    window.location.href = '/miembros/login';
  }

  const profile = document.getElementById('profile');
  const feedback = document.getElementById('feedback');
  const coursesSummary = document.getElementById('courses-summary');
  const assignmentSummary = document.getElementById('assignment-summary');
  const routeCards = document.getElementById('route-cards');
  const adminLink = document.getElementById('admin-link');
  const logoutBtn = document.getElementById('logout-btn');
  const LAST_WORKSHOP_KEY = 'ediprofe_member_last_workshop';
  const LAST_SIMULACRO_KEY = 'ediprofe_member_last_simulacro';
  const LAST_ASSIGNMENT_KEY = 'ediprofe_member_last_assignment';

  function statusClass(status) {
    if (status === 'approved') return 'approved';
    if (status === 'blocked') return 'blocked';
    return 'approved';
  }

  function statusLabel(status) {
    if (status === 'approved') return 'Activo';
    if (status === 'blocked') return 'Bloqueado';
    return 'Activo';
  }

  function roleLabel(role) {
    if (role === 'admin') return 'Administrador';
    return 'Estudiante';
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function normalizeWorkshopList(response) {
    const firstLevel = response?.data;
    if (Array.isArray(firstLevel)) {
      return firstLevel;
    }

    if (Array.isArray(firstLevel?.data)) {
      return firstLevel.data;
    }

    return [];
  }

  function renderCourses(courses) {
    if (!Array.isArray(courses) || courses.length === 0) {
      coursesSummary.innerHTML =
        '<div class="members-alert">Todavía no tienes cursos con biblioteca asignada.</div>';
      return;
    }

    coursesSummary.innerHTML = `
      <div class="members-list members-list--tight">
        ${courses
          .map(
            (course) => `
          <article class="members-item course-item" style="padding: 0.75rem 1rem;">
            <div class="u-flex-between" style="align-items: center;">
              <h4 style="margin:0; font-size: 1rem;">${escapeHtml(course.name)}</h4>
              <span class="members-pill approved">📖 ${Number(course?.stats?.contents || 0)}</span>
            </div>
          </article>
        `
          )
          .join('')}
      </div>
    `;
  }

  function getStoredActivity(key) {
    const raw = window.localStorage.getItem(key);
    if (!raw) return null;

    try {
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  function renderRouteCards(assignments, workshops, simulacros) {
    const lastAssignment = getStoredActivity(LAST_ASSIGNMENT_KEY);
    const lastWorkshop = getStoredActivity(LAST_WORKSHOP_KEY);
    const lastSimulacro = getStoredActivity(LAST_SIMULACRO_KEY);

    const activeAssignments = assignments.filter((item) => item?.availability?.can_view);
    const assignmentsWithReview = assignments.filter((item) => item?.latest_attempt?.can_review);
    const availableWorkshops = workshops.filter((item) => item?.can_access);
    const availableSimulacros = simulacros.filter((item) => item?.can_access);
    const workshopQuestions = availableWorkshops.reduce((acc, item) => acc + Number(item?.stats?.total_questions || 0), 0);
    const simulacroQuestions = availableSimulacros.reduce((acc, item) => acc + Number(item?.stats?.total_questions || 0), 0);

    routeCards.innerHTML = `
      <a class="members-quick-link" href="/miembros/asignaciones">
        <strong>📝 Evaluaciones</strong>
        <p>Lo que tu docente te dejó asignado. Desde aquí inicias, continúas o revisas retroalimentación.</p>
        <span class="members-route-metric">📌 ${activeAssignments.length} en tu panel</span>
        <span class="members-route-metric">💬 ${assignmentsWithReview.length} con retroalimentación</span>
        <div class="members-route-actions">
          <span class="members-button">${lastAssignment?.link ? 'Continuar' : 'Ver evaluaciones'}</span>
        </div>
      </a>

      <a class="members-quick-link" href="/miembros/talleres">
        <strong>✍️ Talleres</strong>
        <p>Práctica por tema con revisión inmediata, ideal para reforzar antes de una evaluación.</p>
        <span class="members-route-metric">📚 ${availableWorkshops.length} disponibles</span>
        <span class="members-route-metric">📄 ${workshopQuestions} preguntas activas</span>
        <div class="members-route-actions">
          <span class="members-button">${lastWorkshop?.link ? 'Seguir taller' : 'Abrir talleres'}</span>
        </div>
      </a>

      <a class="members-quick-link" href="/miembros/simulacros">
        <strong>🚀 Simulacros</strong>
        <p>Ensayos completos en formato de examen para medir avance y preparar resultados reales.</p>
        <span class="members-route-metric">🏁 ${availableSimulacros.length} disponibles</span>
        <span class="members-route-metric">📄 ${simulacroQuestions} preguntas activas</span>
        <div class="members-route-actions">
          <span class="members-button">${lastSimulacro?.link ? 'Seguir simulacro' : 'Abrir simulacros'}</span>
        </div>
      </a>
    `;
  }

  function renderAssignmentSummary(items) {
    const total = items.length;
    const activeNow = items.filter((item) => item?.availability?.can_start);
    const lastAssignment = getStoredActivity(LAST_ASSIGNMENT_KEY);
    const recent = items.slice(0, 3);
    const reviewReady = items.filter((item) => item?.latest_attempt?.can_review).length;

    const recentHtml =
      recent.length > 0
        ? recent
            .map((item) => {
              const link = `/miembros/asignaciones/abrir?id=${encodeURIComponent(item.id)}`;
              const latest = item?.latest_attempt;
              const actionLabel =
                latest?.status === 'in_progress'
                  ? 'Continuar'
                  : latest?.can_review
                  ? 'Revisar'
                  : latest
                  ? 'Abrir'
                  : 'Comenzar';

              return `
              <article class="members-item compact">
                <div class="members-item-main">
                  <h4 style="font-size: 0.95rem;">${escapeHtml(item.title)}</h4>
                  <p class="members-subtitle">${item?.course?.name || ''}</p>
                </div>
                <div class="members-actions">
                  <a class="members-button" style="padding: 0.3rem 0.6rem; font-size: 0.8rem;" href="${link}">${actionLabel}</a>
                </div>
              </article>
            `;
            })
            .join('')
        : '<div class="members-alert">No tienes evaluaciones disponibles en este momento.</div>';

    assignmentSummary.innerHTML = `
      <div class="members-info-bar" style="margin-top:0; padding-top:0; border-top:none;">
        <p>📌 <strong>${activeNow.length}</strong> activas ahora · 💬 <strong>${reviewReady}</strong> con retroalimentación · 🗂️ <strong>${total}</strong> registradas</p>
      </div>

      ${
        lastAssignment?.link
          ? `
        <div class="members-card continue-card u-margin-bottom-medium">
          <p class="continue-card-label">Lo más reciente</p>
          <h4 class="u-margin-bottom-small">${escapeHtml(lastAssignment.title || 'Evaluación reciente')}</h4>
          <a class="members-button u-full-width" href="${escapeHtml(lastAssignment.link)}">Abrir evaluación</a>
        </div>
      `
          : ''
      }

      <div class="members-list members-list--tight">
        ${recentHtml}
      </div>
    `;
  }

  function renderFallbackRouteCards() {
    routeCards.innerHTML = `
      <a class="members-quick-link" href="/miembros/asignaciones">
        <strong>📝 Evaluaciones</strong>
        <p>Consulta lo que tu docente dejó asignado y revisa tus resultados.</p>
      </a>
      <a class="members-quick-link" href="/miembros/talleres">
        <strong>✍️ Talleres</strong>
        <p>Practica por tema con retroalimentación inmediata.</p>
      </a>
      <a class="members-quick-link" href="/miembros/simulacros">
        <strong>🚀 Simulacros</strong>
        <p>Entrena con pruebas completas en formato de examen.</p>
      </a>
    `;
  }

  function renderBlockedState() {
    routeCards.innerHTML = '';
    coursesSummary.innerHTML = '<div class="members-alert error">Sin acceso a cursos.</div>';
    assignmentSummary.innerHTML = '<div class="members-alert error">Acceso bloqueado.</div>';
  }

  function renderInitialState() {
    renderFallbackRouteCards();
  }

  function renderDashboardData(assignments, workshops, simulacros) {
    renderRouteCards(assignments, workshops, simulacros);
    renderAssignmentSummary(assignments);
  }

  async function boot() {
    try {
      renderInitialState();
      const me = await apiMe();
      const user = me?.data?.user;
      if (!user) {
        throw new Error('No se pudo resolver sesión.');
      }

      saveSession(token, user);

      profile.innerHTML = `
        <div class="profile-main-info">
          <div class="profile-avatar">👨‍🎓</div>
          <div class="profile-text">
            <h4>${user.name}</h4>
            <p>${user.email}</p>
          </div>
        </div>
        <div class="profile-stats-row">
          <div class="profile-stat-item">
            <label>Rol</label>
            <span>${roleLabel(user.role || 'student')}</span>
          </div>
          <div class="profile-stat-item">
            <label>Estado</label>
            <span class="members-pill ${statusClass(user.member_status)}">${statusLabel(user.member_status)}</span>
          </div>
          <div class="profile-stat-item">
            <label>Acceso</label>
            <span>${user.auth_provider === 'google' ? 'Acceso con Google' : 'Cuenta académica'}</span>
          </div>
        </div>
      `;

      if (user.role === 'admin') {
        adminLink.style.display = 'inline-flex';
      }

      if (user.member_status === 'blocked') {
        feedback.innerHTML = `<div class="members-alert error">Tu cuenta fue bloqueada. Contacta al administrador.</div>`;
        renderBlockedState();
      } else {
        const [coursesResponse, assignmentsResponse, workshopsResponse, simulacrosResponse] = await Promise.all([
          apiMyCourses(),
          apiMyAssignments(),
          apiMyLibrary({ contentType: 'taller' }),
          apiMyLibrary({ contentType: 'simulacro' }),
        ]);

        const assignments = Array.isArray(assignmentsResponse?.data) ? assignmentsResponse.data : [];
        const workshops = normalizeWorkshopList(workshopsResponse);
        const simulacros = normalizeWorkshopList(simulacrosResponse);

        renderCourses(Array.isArray(coursesResponse?.data) ? coursesResponse.data : []);
        renderDashboardData(assignments, workshops, simulacros);
      }
    } catch (error) {
      clearSession();
      window.location.href = '/miembros/login';
    }
  }

  logoutBtn?.addEventListener('click', async () => {
    await apiLogout();
    window.location.href = '/miembros/login';
  });

  boot();
</script>
