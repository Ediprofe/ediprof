---
import MembersEditorialLayout from '../../layouts/MembersEditorialLayout.astro';
---

<MembersEditorialLayout
  title="Panel del Estudiante"
  description="Revisa tu estado, tus cursos y la biblioteca disponible dentro de Ediprofe."
  badge="Miembros"
  icon="🧭"
>
  <div class="practice-surface members-editorial-stack">
    <section class="practice-toolbar">
      <div class="practice-toolbar-copy">
        <p class="practice-toolbar-label">Biblioteca institucional</p>
        <h2 class="practice-toolbar-title">Tu ruta de estudio</h2>
        <p class="practice-toolbar-desc">Accede a talleres y simulacros según los cursos asignados por el docente.</p>
      </div>
      <div class="practice-toolbar-actions">
        <a class="members-button secondary" href="/miembros/asignaciones">Asignaciones</a>
        <a class="members-button secondary" href="/miembros/talleres">Talleres</a>
        <a class="members-button secondary" href="/miembros/simulacros">Simulacros</a>
        <a class="members-button secondary" href="/miembros/admin" id="admin-link" style="display:none;">Administración</a>
        <button class="members-button warn" id="logout-btn" type="button">Cerrar sesión</button>
      </div>
    </section>

    <section class="members-card">
      <div id="profile"></div>
      <div id="feedback"></div>
    </section>

    <section class="members-card">
      <h3 class="members-section-title">Mis cursos</h3>
      <div id="courses-summary"></div>
    </section>

    <section class="members-card">
      <h3 class="members-section-title">Ruta de práctica</h3>
      <div id="route"></div>
    </section>

    <section class="members-card">
      <h3 class="members-section-title">Asignaciones y entregas</h3>
      <div id="assignment-summary"></div>
    </section>

    <section class="members-card">
      <h3 class="members-section-title">Tus talleres</h3>
      <div id="workshop-summary"></div>
    </section>

    <section class="members-card">
      <h3 class="members-section-title">Tus simulacros</h3>
      <div id="simulacro-summary"></div>
    </section>
  </div>
</MembersEditorialLayout>

<script>
  import {
    apiLogout,
    apiMe,
    apiMyAssignments,
    apiMyCourses,
    apiMyLibrary,
    clearSession,
    getSessionToken,
    saveSession,
  } from '../../scripts/members/client';

  const token = getSessionToken();
  if (!token) {
    window.location.href = '/miembros/login';
  }

  const profile = document.getElementById('profile');
  const feedback = document.getElementById('feedback');
  const coursesSummary = document.getElementById('courses-summary');
  const routeWrap = document.getElementById('route');
  const assignmentSummary = document.getElementById('assignment-summary');
  const workshopSummary = document.getElementById('workshop-summary');
  const simulacroSummary = document.getElementById('simulacro-summary');
  const adminLink = document.getElementById('admin-link');
  const logoutBtn = document.getElementById('logout-btn');
  const LAST_WORKSHOP_KEY = 'ediprofe_member_last_workshop';
  const LAST_SIMULACRO_KEY = 'ediprofe_member_last_simulacro';
  const LAST_ASSIGNMENT_KEY = 'ediprofe_member_last_assignment';

  function statusClass(status) {
    if (status === 'approved') return 'approved';
    if (status === 'blocked') return 'blocked';
    return 'approved';
  }

  function statusLabel(status) {
    if (status === 'approved') return 'Activo';
    if (status === 'blocked') return 'Bloqueado';
    return 'Activo';
  }

  function toBase64Url(value) {
    const utf8 = encodeURIComponent(value).replace(/%([0-9A-F]{2})/g, (_, p1) =>
      String.fromCharCode(Number.parseInt(p1, 16))
    );

    return btoa(utf8).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function normalizeWorkshopList(response) {
    const firstLevel = response?.data;
    if (Array.isArray(firstLevel)) {
      return firstLevel;
    }

    if (Array.isArray(firstLevel?.data)) {
      return firstLevel.data;
    }

    return [];
  }

  function renderRoute(isBlocked) {
    routeWrap.innerHTML = `
      <div class="members-steps">
        <article class="members-step done">
          <strong>1. Ingreso institucional</strong>
          <p>Acceso con tu correo del colegio.</p>
        </article>
        <article class="members-step ${isBlocked ? '' : 'done'}">
          <strong>2. Cursos asignados</strong>
          <p>${isBlocked ? 'Tu cuenta está bloqueada y no puede usar la biblioteca.' : 'Tus cursos habilitan la biblioteca disponible.'}</p>
        </article>
        <article class="members-step ${isBlocked ? '' : 'done'}">
          <strong>3. Biblioteca libre</strong>
          <p>${isBlocked ? 'No disponible mientras el acceso esté bloqueado.' : 'Puedes practicar en modo estudio o simulacro libre.'}</p>
        </article>
        <article class="members-step ${isBlocked ? '' : 'done'}">
          <strong>4. Retroalimentación</strong>
          <p>${isBlocked ? 'La retroalimentación se habilita cuando vuelvas a tener acceso.' : 'Profundiza con solución guiada y conceptos relacionados.'}</p>
        </article>
      </div>
    `;
  }

  function renderCourses(courses) {
    if (!Array.isArray(courses) || courses.length === 0) {
      coursesSummary.innerHTML =
        '<div class="members-alert">Todavía no tienes cursos con biblioteca asignada.</div>';
      return;
    }

    coursesSummary.innerHTML = `
      <div class="members-grid">
        ${courses
          .map(
            (course) => `
          <article class="members-item">
            <h4>${escapeHtml(course.name)}</h4>
            <p>${escapeHtml(course.school_year || '2026')}</p>
            <p style="margin-top:0.35rem;">
              <span class="members-pill approved">${Number(course?.stats?.contents || 0)} contenidos</span>
              <span class="members-pill pending" style="margin-left:0.35rem;">${Number(course?.stats?.simulacros || 0)} simulacros</span>
            </p>
          </article>
        `
          )
          .join('')}
      </div>
    `;
  }

  function renderWorkshopSummary(items) {
    const total = items.length;
    const accessible = items.filter((item) => item.can_access);
    const totalQuestions = accessible.reduce((acc, item) => acc + Number(item?.stats?.total_questions || 0), 0);
    const lastWorkshopRaw = window.localStorage.getItem(LAST_WORKSHOP_KEY);
    let lastWorkshop = null;
    if (lastWorkshopRaw) {
      try {
        lastWorkshop = JSON.parse(lastWorkshopRaw);
      } catch {
        lastWorkshop = null;
      }
    }

    const recent = accessible.slice(0, 3);
    const recentHtml =
      recent.length > 0
        ? recent
            .map((item) => {
              const link = `/miembros/talleres/${toBase64Url(item.id)}`;
              return `
              <article class="members-item">
                <h4>${escapeHtml(item.title)}</h4>
                <p>${escapeHtml(item.area_slug || 'general')} · ${Number(item?.stats?.total_questions || 0)} preguntas</p>
                <div class="members-actions" style="margin-top:0.55rem;">
                  <a class="members-button" href="${link}">Practicar</a>
                </div>
              </article>
            `;
            })
            .join('')
        : '<div class="members-alert">No tienes talleres con acceso todavía.</div>';

    workshopSummary.innerHTML = `
      <div class="members-grid">
        <article class="members-item">
          <h4>Talleres totales</h4>
          <p>${total}</p>
        </article>
        <article class="members-item">
          <h4>Con acceso</h4>
          <p>${accessible.length}</p>
        </article>
        <article class="members-item">
          <h4>Preguntas disponibles</h4>
          <p>${totalQuestions}</p>
        </article>
      </div>
      ${
        lastWorkshop?.link
          ? `
        <div class="members-actions" style="margin-top:0.9rem;">
          <a class="members-button" href="${escapeHtml(lastWorkshop.link)}">Continuar último taller</a>
          <span class="members-pill pending">${escapeHtml(lastWorkshop.title || 'Taller reciente')}</span>
        </div>
      `
          : ''
      }
      <div class="members-list" style="margin-top:0.9rem;">
        ${recentHtml}
      </div>
      <div class="members-actions" style="margin-top:0.75rem;">
        <a class="members-button secondary" href="/miembros/talleres">Ver catálogo completo</a>
      </div>
    `;
  }

  function renderSimulacroSummary(items) {
    const total = items.length;
    const accessible = items.filter((item) => item.can_access);
    const totalQuestions = accessible.reduce((acc, item) => acc + Number(item?.stats?.total_questions || 0), 0);
    const lastSimulacroRaw = window.localStorage.getItem(LAST_SIMULACRO_KEY);
    let lastSimulacro = null;
    if (lastSimulacroRaw) {
      try {
        lastSimulacro = JSON.parse(lastSimulacroRaw);
      } catch {
        lastSimulacro = null;
      }
    }

    const recent = accessible.slice(0, 3);
    const recentHtml =
      recent.length > 0
        ? recent
            .map((item) => {
              const link = `/miembros/simulacros/${toBase64Url(item.id)}`;
              return `
              <article class="members-item">
                <h4>${escapeHtml(item.title)}</h4>
                <p>${escapeHtml(item.area_slug || 'general')} · ${Number(item?.stats?.total_questions || 0)} preguntas</p>
                <div class="members-actions" style="margin-top:0.55rem;">
                  <a class="members-button" href="${link}">Abrir</a>
                </div>
              </article>
            `;
            })
            .join('')
        : '<div class="members-alert">No tienes simulacros con acceso todavía.</div>';

    simulacroSummary.innerHTML = `
      <div class="members-grid">
        <article class="members-item">
          <h4>Simulacros totales</h4>
          <p>${total}</p>
        </article>
        <article class="members-item">
          <h4>Con acceso</h4>
          <p>${accessible.length}</p>
        </article>
        <article class="members-item">
          <h4>Preguntas disponibles</h4>
          <p>${totalQuestions}</p>
        </article>
      </div>
      ${
        lastSimulacro?.link
          ? `
        <div class="members-actions" style="margin-top:0.9rem;">
          <a class="members-button" href="${escapeHtml(lastSimulacro.link)}">Continuar último simulacro</a>
          <span class="members-pill pending">${escapeHtml(lastSimulacro.title || 'Simulacro reciente')}</span>
        </div>
      `
          : ''
      }
      <div class="members-list" style="margin-top:0.9rem;">
        ${recentHtml}
      </div>
      <div class="members-actions" style="margin-top:0.75rem;">
        <a class="members-button secondary" href="/miembros/simulacros">Ver catálogo completo</a>
      </div>
    `;
  }

  function renderAssignmentSummary(items) {
    const total = items.length;
    const activeNow = items.filter((item) => item?.availability?.can_start);
    const reviewable = items.filter((item) => item?.latest_attempt?.can_review).length;
    const evaluations = items.filter((item) => item?.mode === 'evaluation').length;
    const totalQuestions = items.reduce((acc, item) => acc + Number(item?.stats?.effective_questions || 0), 0);
    const lastAssignmentRaw = window.localStorage.getItem(LAST_ASSIGNMENT_KEY);
    let lastAssignment = null;
    if (lastAssignmentRaw) {
      try {
        lastAssignment = JSON.parse(lastAssignmentRaw);
      } catch {
        lastAssignment = null;
      }
    }

    const recent = items.slice(0, 3);
    const recentHtml =
      recent.length > 0
        ? recent
            .map((item) => {
              const link = `/miembros/asignaciones/abrir?id=${encodeURIComponent(item.id)}`;
              const modeLabel =
                item.mode === 'study' ? 'Estudio guiado' : item.mode === 'evaluation' ? 'Evaluación' : 'Simulacro';
              const feedbackLabel = item?.feedback?.state_label || item?.feedback?.policy_label || 'Retroalimentación';
              const feedbackClass =
                item?.feedback?.state === 'available'
                  ? 'approved'
                  : 'pending';
              const attemptStatusLabel =
                item?.latest_attempt?.status === 'in_progress'
                  ? 'En progreso'
                  : item?.latest_attempt?.status === 'submitted'
                  ? 'Entregada'
                  : item?.latest_attempt?.status === 'graded'
                  ? 'Calificada'
                  : item?.latest_attempt?.status === 'released'
                  ? 'Retro liberada'
                  : 'Sin intento';
              const actionLabel =
                item?.latest_attempt?.status === 'in_progress'
                  ? 'Continuar'
                  : item?.latest_attempt?.can_review
                  ? 'Ver retroalimentación'
                  : item?.latest_attempt
                  ? 'Ver resultado'
                  : 'Abrir';

              return `
              <article class="members-item">
                <h4>${escapeHtml(item.title)}</h4>
                <p>${escapeHtml(modeLabel)} · ${Number(item?.stats?.effective_questions || 0)} preguntas</p>
                ${
                  item?.course?.name
                    ? `<p style="margin-top:0.35rem;"><span class="members-pill approved">${escapeHtml(item.course.name)}</span></p>`
                    : ''
                }
                <p style="margin-top:0.45rem;">
                  <span class="members-pill ${item?.availability?.can_start ? 'approved' : 'pending'}">${
                    item?.availability?.can_start ? 'Disponible' : 'Seguimiento'
                  }</span>
                  ${
                    item?.feedback
                      ? `<span class="members-pill ${feedbackClass}" style="margin-left:0.35rem;">${escapeHtml(feedbackLabel)}</span>`
                      : ''
                  }
                  ${
                    item?.latest_attempt
                      ? `<span class="members-pill pending" style="margin-left:0.35rem;">Intento: ${escapeHtml(attemptStatusLabel)}</span>`
                      : ''
                  }
                  ${
                    item?.attempts?.limit
                      ? `<span class="members-pill pending" style="margin-left:0.35rem;">Intentos ${Number(item?.attempts?.used || 0)}/${Number(item?.attempts?.limit || 0)}</span>`
                      : ''
                  }
                </p>
                ${
                  item?.feedback?.message
                    ? `<p style="margin-top:0.45rem;">${escapeHtml(item.feedback.message)}</p>`
                    : ''
                }
                <div class="members-actions" style="margin-top:0.55rem;">
                  <a class="members-button" href="${link}" data-assignment-link="${escapeHtml(link)}" data-assignment-title="${escapeHtml(item.title)}">
                    ${actionLabel}
                  </a>
                </div>
              </article>
            `;
            })
            .join('')
        : '<div class="members-alert">No tienes asignaciones disponibles todavía.</div>';

    assignmentSummary.innerHTML = `
      <div class="members-grid">
        <article class="members-item">
          <h4>Asignaciones visibles</h4>
          <p>${total}</p>
        </article>
        <article class="members-item">
          <h4>Disponibles ahora</h4>
          <p>${activeNow.length}</p>
        </article>
        <article class="members-item">
          <h4>Evaluaciones</h4>
          <p>${evaluations}</p>
        </article>
        <article class="members-item">
          <h4>Retro disponible</h4>
          <p>${reviewable}</p>
        </article>
        <article class="members-item">
          <h4>Preguntas comprometidas</h4>
          <p>${totalQuestions}</p>
        </article>
      </div>
      ${
        lastAssignment?.link
          ? `
        <div class="members-actions" style="margin-top:0.9rem;">
          <a class="members-button" href="${escapeHtml(lastAssignment.link)}">Continuar última asignación</a>
          <span class="members-pill pending">${escapeHtml(lastAssignment.title || 'Asignación reciente')}</span>
        </div>
      `
          : ''
      }
      <div class="members-list" style="margin-top:0.9rem;">
        ${recentHtml}
      </div>
      <div class="members-actions" style="margin-top:0.75rem;">
        <a class="members-button secondary" href="/miembros/asignaciones">Ver todas las asignaciones</a>
      </div>
    `;

    assignmentSummary.querySelectorAll('a[data-assignment-link]').forEach((anchor) => {
      anchor.addEventListener('click', () => {
        const link = anchor.getAttribute('data-assignment-link');
        const title = anchor.getAttribute('data-assignment-title');
        if (!link) return;
        window.localStorage.setItem(
          LAST_ASSIGNMENT_KEY,
          JSON.stringify({
            link,
            title: title || 'Asignación',
            at: Date.now(),
          })
        );
      });
    });
  }

  async function boot() {
    try {
      const me = await apiMe();
      const user = me?.data?.user;
      if (!user) {
        throw new Error('No se pudo resolver sesión.');
      }

      saveSession(token, user);

      profile.innerHTML = `
        <div class="members-grid">
          <div class="members-item">
            <h4>${user.name}</h4>
            <p>${user.email}</p>
          </div>
          <div class="members-item">
            <h4>Rol</h4>
            <p>${user.role || 'student'}</p>
          </div>
          <div class="members-item">
            <h4>Estado</h4>
            <p><span class="members-pill ${statusClass(user.member_status)}">${statusLabel(user.member_status)}</span></p>
          </div>
          <div class="members-item">
            <h4>Acceso</h4>
            <p>${user.auth_provider === 'google' ? 'Google institucional' : 'Correo y contraseña'}</p>
          </div>
        </div>
      `;

      if (user.role === 'admin') {
        adminLink.style.display = 'inline-flex';
      }

      renderRoute(user.member_status === 'blocked');

      if (user.member_status === 'blocked') {
        feedback.innerHTML = `<div class="members-alert error">Tu cuenta fue bloqueada. Contacta al administrador.</div>`;
        coursesSummary.innerHTML =
          '<div class="members-alert error">No tienes acceso a cursos mientras tu cuenta esté bloqueada.</div>';
        assignmentSummary.innerHTML =
          '<div class="members-alert error">Tu acceso a asignaciones académicas está bloqueado. Contacta al administrador.</div>';
        workshopSummary.innerHTML =
          '<div class="members-alert error">Tu acceso premium está bloqueado. Contacta al administrador.</div>';
        simulacroSummary.innerHTML =
          '<div class="members-alert error">Tu acceso premium está bloqueado. Contacta al administrador.</div>';
      } else {
        const [coursesResponse, assignmentsResponse, workshopsResponse, simulacrosResponse] = await Promise.all([
          apiMyCourses(),
          apiMyAssignments(),
          apiMyLibrary({ contentType: 'taller' }),
          apiMyLibrary({ contentType: 'simulacro' }),
        ]);

        renderCourses(Array.isArray(coursesResponse?.data) ? coursesResponse.data : []);
        renderAssignmentSummary(Array.isArray(assignmentsResponse?.data) ? assignmentsResponse.data : []);
        renderWorkshopSummary(normalizeWorkshopList(workshopsResponse));
        renderSimulacroSummary(normalizeWorkshopList(simulacrosResponse));
      }
    } catch (error) {
      clearSession();
      window.location.href = '/miembros/login';
    }
  }

  logoutBtn?.addEventListener('click', async () => {
    await apiLogout();
    window.location.href = '/miembros/login';
  });

  boot();
</script>
