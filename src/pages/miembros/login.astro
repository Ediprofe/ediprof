---
import MembersEditorialLayout from '../../layouts/MembersEditorialLayout.astro';
---

<MembersEditorialLayout
  title="Zona de Estudiantes"
  description="Ingresa con tu cuenta institucional para ver tu biblioteca de talleres y simulacros de Ediprofe."
  badge="Miembros premium"
  icon="🎓"
  breadcrumbTrail={[{ label: 'Acceso institucional' }]}
>
  <div class="practice-surface members-editorial-stack">
    <section class="practice-panel">
      <h2 class="practice-panel-title">Ruta de acceso</h2>
      <div class="members-grid">
        <article class="members-item">
          <h3 class="members-section-title" style="margin-bottom:0.35rem;">Estudiantes</h3>
          <p class="members-subtitle">Entran con Google institucional y acceden a la biblioteca de su curso.</p>
        </article>
        <article class="members-item">
          <h3 class="members-section-title" style="margin-bottom:0.35rem;">Administración</h3>
          <p class="members-subtitle">El acceso local queda reservado para panel académico y pruebas de desarrollo.</p>
        </article>
      </div>
    </section>

    <section class="members-editorial-grid members-editorial-grid--login">
      <article class="members-card members-editorial-card members-login-panel--student">
        <h3 class="members-section-title" style="margin-bottom:0.35rem;">Acceso estudiantil</h3>
        <p class="members-subtitle" style="margin-bottom:0.85rem;">
          Usa tu cuenta institucional <strong>@sanjoseitagui.edu.co</strong>.
        </p>
        <div id="google-login-wrap" class="members-alert" style="margin-top:0;">
          <div id="google-login-button"></div>
        </div>
        <div id="google-feedback"></div>
      </article>

      <article class="members-card members-editorial-card members-login-panel--admin">
        <details>
          <summary class="members-section-title" style="cursor:pointer;">Acceso administrativo</summary>
          <form id="login-form" class="members-form" style="margin-top:0.85rem;">
            <label class="members-label" for="api-base">API Base URL</label>
            <input id="api-base" class="members-input" type="url" required />

            <label class="members-label" for="email">Correo</label>
            <input id="email" class="members-input" type="email" required />

            <label class="members-label" for="password">Contraseña</label>
            <input id="password" class="members-input" type="password" required />

            <div class="members-actions">
              <button class="members-button" type="submit">Iniciar sesión</button>
            </div>
          </form>
        </details>
      </article>
    </section>

    <div id="feedback"></div>
  </div>
</MembersEditorialLayout>

<script src="https://accounts.google.com/gsi/client" async defer></script>

<script>
  import { apiGoogleLogin, apiLogin, getApiBase, saveSession, setApiBase } from '../../scripts/members/client';

  const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
  const form = document.getElementById('login-form');
  const feedback = document.getElementById('feedback');
  const googleFeedback = document.getElementById('google-feedback');
  const googleLoginWrap = document.getElementById('google-login-wrap');
  const googleButton = document.getElementById('google-login-button');
  const apiBaseInput = document.getElementById('api-base');

  apiBaseInput.value = getApiBase();

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function setGoogleMessage(message, type = 'error') {
    googleFeedback.innerHTML = `<div class="members-alert ${type === 'error' ? 'error' : 'ok'}">${escapeHtml(message)}</div>`;
  }

  async function handleGoogleCredential(credential) {
    try {
      const response = await apiGoogleLogin({
        credential,
        device_name: 'web-miembros-google',
      });

      if (!response.data?.token || !response.data?.user) {
        throw new Error('No se recibió token de sesión.');
      }

      saveSession(response.data.token, response.data.user);
      window.location.href = '/miembros';
    } catch (error) {
      const message = error instanceof Error ? error.message : 'No fue posible iniciar sesión con Google.';
      setGoogleMessage(message);
    }
  }

  function bootGoogleLogin() {
    if (!GOOGLE_CLIENT_ID) {
      googleLoginWrap.innerHTML = `
        <div>
          <strong>Google no configurado todavía.</strong>
          <p style="margin:0.45rem 0 0;">Define <code>PUBLIC_GOOGLE_CLIENT_ID</code> en el frontend y <code>GOOGLE_CLIENT_ID</code> en Laravel para activar este acceso.</p>
        </div>
      `;
      return;
    }

    if (!window.google?.accounts?.id || !googleButton) {
      window.setTimeout(bootGoogleLogin, 150);
      return;
    }

    window.google.accounts.id.initialize({
      client_id: GOOGLE_CLIENT_ID,
      callback: async (response) => {
        if (!response?.credential) {
          setGoogleMessage('Google no entregó una credencial válida.');
          return;
        }

        await handleGoogleCredential(response.credential);
      },
    });

    googleButton.innerHTML = '';
    window.google.accounts.id.renderButton(googleButton, {
      theme: 'outline',
      size: 'large',
      text: 'continue_with',
      shape: 'pill',
      width: 320,
    });
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    feedback.innerHTML = '';

    const email = /** @type {HTMLInputElement} */ (document.getElementById('email')).value;
    const password = /** @type {HTMLInputElement} */ (document.getElementById('password')).value;
    const apiBase = apiBaseInput.value;

    try {
      setApiBase(apiBase);
      const response = await apiLogin({
        email,
        password,
        device_name: 'web-miembros',
      });

      if (!response.data?.token || !response.data?.user) {
        throw new Error('No se recibió token de sesión.');
      }

      saveSession(response.data.token, response.data.user);
      window.location.href = '/miembros';
    } catch (error) {
      const message = error instanceof Error ? error.message : 'No fue posible iniciar sesión.';
      feedback.innerHTML = `<div class="members-alert error">${escapeHtml(message)}</div>`;
    }
  });

  bootGoogleLogin();
</script>
