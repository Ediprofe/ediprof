---
import MembersEditorialLayout from '../../../layouts/MembersEditorialLayout.astro';
---

<MembersEditorialLayout
  title="Redirigiendo a cursos"
  description="Te llevamos directamente a la gestión de cursos dentro del panel admin."
  badge="Administración"
  icon="🗂️"
  breadcrumbTrail={[
    { label: 'Administración', href: '/miembros/admin' },
    { label: 'Cursos' },
  ]}
>
  <div class="practice-surface members-editorial-stack">
    <section class="members-card">
      <div id="handoff-status" class="members-alert">Preparando la gestión de cursos…</div>
    </section>
  </div>
</MembersEditorialLayout>

<script>
  import {
    apiAdminPanelHandoff,
    apiMe,
    getSessionToken,
    saveSession,
  } from '../../../scripts/members/client';

  const token = getSessionToken();
  const status = document.getElementById('handoff-status');

  if (!token) {
    window.location.href = '/miembros/login';
  }

  async function boot() {
    try {
      const me = await apiMe();
      const user = me?.data?.user;

      if (!user) {
        throw new Error('No se pudo validar tu sesión.');
      }

      saveSession(token, user);

      if (user.role !== 'admin') {
        status.innerHTML = 'Tu cuenta no tiene permisos para administrar cursos.';
        status.classList.add('error');
        return;
      }

      status.textContent = 'Abriendo la gestión de cursos…';

      const handoff = await apiAdminPanelHandoff('/admin/courses');
      const url = handoff?.data?.url;

      if (!url) {
        throw new Error('No se pudo abrir el módulo de cursos.');
      }

      window.location.href = url;
    } catch (error) {
      status.textContent = error instanceof Error ? error.message : 'No se pudo abrir la gestión de cursos.';
      status.classList.add('error');
    }
  }

  boot();
</script>
