---
import { getCollection } from 'astro:content';
import PracticeLessonLayout from '../../../layouts/PracticeLessonLayout.astro';
import { getMateriaConfig, getMateriaName } from '../../../config/materias';
import { cleanSlug } from '../../../utils/navigation-generator.js';

export async function getStaticPaths() {
  const talleres = await getCollection('saber');
  const paths = new Map();

  for (const taller of talleres) {
    const normalized = cleanSlug(taller.slug);
    const workshopId = `content:saber:${normalized}`;
    const encoded = Buffer.from(workshopId, 'utf8').toString('base64url');
    const [materiaSlug = 'quimica'] = normalized.split('/');
    const config = getMateriaConfig(materiaSlug);
    const title = taller.data.title || `Taller de ${getMateriaName(materiaSlug)}`;
    const description =
      taller.data.description || 'Resuelve las preguntas una por una y comprueba la retroalimentación al instante.';

    paths.set(encoded, {
      params: { id: encoded },
      props: {
        workshopId,
        title,
        description,
        materiaSlug,
        materiaIcon: config.icon,
      },
    });
  }

  return Array.from(paths.values());
}

const {
  workshopId,
  title,
  description,
  materiaSlug = 'quimica',
  materiaIcon = '📝',
} = Astro.props;
const materiaName = getMateriaName(materiaSlug);
---

<PracticeLessonLayout
  title={title}
  description={description}
  materia={materiaSlug}
  badge="Taller premium"
  icon={materiaIcon}
  breadcrumbItems={[
    { label: 'Inicio', href: '/', icon: '🏠' },
    { label: 'Miembros', href: '/miembros', icon: '👥' },
    { label: 'Talleres', href: '/miembros/talleres', icon: '📝' },
    { label: materiaName },
    { label: title },
  ]}
  contentClass="saber-taller"
>
  <div class="practice-surface">
    <div class="members-actions">
      <a class="members-button secondary" href="/miembros/talleres">Volver a talleres</a>
      <button type="button" class="members-button warn" id="reset-progress-btn">Reiniciar progreso</button>
    </div>
    <div id="practice-feedback"></div>
    <div id="practice-player"></div>
  </div>
</PracticeLessonLayout>

<script define:vars={{ workshopId }}>
  window.__EDIPROFE_PRACTICE_ID__ = workshopId;
</script>

<script>
  import {
    apiEvaluate,
    apiMe,
    apiWorkshopDetail,
    clearSession,
    getSessionToken,
    saveSession,
  } from '../../../scripts/members/client';
  import { mountPracticePlayer } from '../../../scripts/members/practicePlayer';

  mountPracticePlayer({
    root: document.getElementById('practice-player'),
    feedback: document.getElementById('practice-feedback'),
    resetButton: document.getElementById('reset-progress-btn'),
    contentId: window.__EDIPROFE_PRACTICE_ID__,
    contentType: 'taller',
    contentLabel: 'Taller interactivo',
    backHref: '/miembros/talleres',
    allowedModes: ['study'],
    defaultMode: 'study',
    api: {
      getSessionToken,
      clearSession,
      saveSession,
      me: apiMe,
      detail: apiWorkshopDetail,
      evaluate: apiEvaluate,
    },
  });
</script>
