---
import MembersEditorialLayout from '../../../layouts/MembersEditorialLayout.astro';
---

<MembersEditorialLayout
  title="Talleres de Práctica"
  description="Selecciona un taller y entrena con retroalimentación inmediata para mejorar tu desempeño."
  badge="Práctica"
  icon="✍️"
  breadcrumbTrail={[{ label: 'Talleres' }]}
  activeSection="talleres"
>
  <div class="practice-surface members-editorial-stack">
    <section class="members-card">
      <div id="feedback"></div>
      <div id="summary" class="u-margin-bottom-large"></div>
      
      <div class="members-list-header">
        <div class="members-item-main">
          <h3 class="members-section-title">📚 Talleres disponibles</h3>
          <p class="members-subtitle">Aquí aparecen los contenidos habilitados para tu curso o nivel académico.</p>
        </div>
        <div class="members-actions">
          <a class="members-button secondary" href="/miembros">Volver al panel</a>
        </div>
      </div>
      <div id="workshops" class="members-list members-list--loose"></div>
    </section>
  </div>
</MembersEditorialLayout>

<script>
  import { apiMe, apiMyLibrary, clearSession, getSessionToken, saveSession } from '../../../scripts/members/client';

  const token = getSessionToken();
  if (!token) {
    window.location.href = '/miembros/login';
  }

  const feedback = document.getElementById('feedback');
  const summary = document.getElementById('summary');
  const workshopsWrap = document.getElementById('workshops');
  const LAST_WORKSHOP_KEY = 'ediprofe_member_last_workshop';

  function toBase64Url(value) {
    const utf8 = encodeURIComponent(value).replace(/%([0-9A-F]{2})/g, (_, p1) =>
      String.fromCharCode(Number.parseInt(p1, 16))
    );

    return btoa(utf8).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function normalizeWorkshopList(response) {
    const firstLevel = response?.data;
    if (Array.isArray(firstLevel)) {
      return firstLevel;
    }

    if (Array.isArray(firstLevel?.data)) {
      return firstLevel.data;
    }

    return [];
  }

  async function boot() {
    try {
      const me = await apiMe();
      const user = me?.data?.user;
      if (!user) {
        throw new Error('Sesión inválida.');
      }

      saveSession(token, user);

      if (user.member_status === 'blocked' && user.role !== 'admin') {
        feedback.innerHTML = `
          <div class="members-alert error">
            Acceso restringido. Contacta al administrador.
          </div>
        `;
        return;
      }

      const response = await apiMyLibrary({ contentType: 'taller' });
      const items = normalizeWorkshopList(response);

      if (items.length === 0) {
        workshopsWrap.innerHTML =
          '<div class="members-alert">No hay talleres disponibles en este momento.</div>';
        return;
      }

      const withAccess = items.filter((item) => item.can_access);
      const totalQuestions = withAccess.reduce((acc, item) => acc + Number(item?.stats?.total_questions || 0), 0);
      
      summary.innerHTML = `
        <div class="members-grid summary-stats">
          <article class="members-item stat-box">
            <p class="members-subtitle">Disponibles</p>
            <p class="stat-value" style="color: #27ae60;">${withAccess.length}</p>
          </article>
          <article class="members-item stat-box">
            <p class="members-subtitle">Totales</p>
            <p class="stat-value">${items.length}</p>
          </article>
          <article class="members-item stat-box">
            <p class="members-subtitle">Preguntas</p>
            <p class="stat-value" style="color: var(--color-primary);">${totalQuestions}</p>
          </article>
        </div>
      `;

      workshopsWrap.innerHTML = items
        .map((item) => {
          const link = `/miembros/talleres/${toBase64Url(item.id)}`;
          const canAccess = item.can_access;
          const statusClass = canAccess ? 'approved' : 'blocked';
          const statusLabel = canAccess ? '✅ Disponible' : '🔒 Bloqueado';
          const statusModifier = canAccess ? 'approved' : 'blocked';

          return `
            <article class="members-item members-item--${statusModifier}">
              <div class="u-flex-between">
                <div class="members-item-main">
                  <h4 class="u-margin-bottom-small" style="font-size: 1.25rem;">${escapeHtml(item.title)}</h4>
                  <p class="members-subtitle u-margin-bottom-medium" style="font-size: 1rem;">
                    📚 ${escapeHtml(item.area_slug || 'general')} · 📄 ${Number(item.stats?.total_questions || 0)} preguntas
                  </p>
                  
                  <div class="u-flex-wrap u-flex-gap-small u-margin-bottom-medium">
                    <span class="members-pill ${statusClass}">${statusLabel}</span>
                    ${
                      Array.isArray(item.course_names) && item.course_names.length > 0
                        ? item.course_names
                            .map((course) => `<span class="members-pill approved">🎓 ${escapeHtml(course.name)}</span>`)
                            .join(' ')
                        : ''
                    }
                  </div>
                </div>
                
                <div class="members-actions" style="min-width: 150px; justify-content: flex-end;">
                  <a
                    class="members-button ${canAccess ? '' : 'secondary'}"
                    href="${canAccess ? link : '#'}"
                    data-link="${escapeHtml(link)}"
                    data-title="${escapeHtml(item.title)}"
                    ${canAccess ? '' : 'onclick="return false;" style="opacity: 0.5; cursor: not-allowed;"'}
                    style="width: 100%; padding: 0.8rem;"
                  >
                    ${canAccess ? 'Iniciar práctica' : 'No disponible'}
                  </a>
                </div>
              </div>
            </article>
          `;
        })
        .join('');

      workshopsWrap.querySelectorAll('a[data-link]').forEach((anchor) => {
        anchor.addEventListener('click', () => {
          const link = anchor.getAttribute('data-link');
          const title = anchor.getAttribute('data-title');
          if (!link) return;
          window.localStorage.setItem(
            LAST_WORKSHOP_KEY,
            JSON.stringify({
              link,
              title: title || 'Taller',
              at: Date.now(),
            })
          );
        });
      });
    } catch (error) {
      clearSession();
      window.location.href = '/miembros/login';
    }
  }

  boot();
</script>
